# =============================================================================
# Home Server Stack - Environment Configuration
# =============================================================================
# Copy this file to .env and customize the values for your environment
# DO NOT commit .env to version control - it may contain sensitive data
#
# Usage: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# User and Group Configuration
# -----------------------------------------------------------------------------
# PUID and PGID should match your host user to avoid permission issues
# Find your UID/GID: id -u (UID) and id -g (GID)
PUID=1000
PGID=1000

# -----------------------------------------------------------------------------
# Timezone Configuration
# -----------------------------------------------------------------------------
# All services will use this timezone for scheduling and logging
# Format: Area/City (e.g., Europe/Vienna, America/New_York, Asia/Tokyo)
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Vienna

# -----------------------------------------------------------------------------
# Directory Configuration
# -----------------------------------------------------------------------------
# Base directory for all Docker configurations
DOCKER_BASE_DIR=/data/docker

# Infrastructure configuration directory
INFRASTRUCTURE_CONFIG_DIR=${DOCKER_BASE_DIR}/infrastructure/config

# Arr-stack configuration directory
ARR_CONFIG_DIR=${DOCKER_BASE_DIR}/arr-stack/config

# Media directory — NFS mount from onigashima:/media
# Subdirectories: movies, tvseries, anime, music, iptv
MEDIA_DIR=/mnt/media

# Downloads directory — NFS mount from onigashima:/downloads
# Deluge writes here; *arr apps read/move from here
DOWNLOADS_DIR=/mnt/downloads

# -----------------------------------------------------------------------------
# Network Configuration
# -----------------------------------------------------------------------------
# Docker network subnets for inter-container communication
# Default should work for most setups - only change if you have conflicts
DOCKER_SUBNET=172.18.0.0/16
INFRASTRUCTURE_SUBNET=172.19.0.0/16

# -----------------------------------------------------------------------------
# Domain and HTTPS Configuration
# -----------------------------------------------------------------------------
# Your domain name for accessing services via HTTPS subdomains
# Example: yourdomain.com will create radarr.yourdomain.com, sonarr.yourdomain.com, etc.
DOMAIN=yourdomain.com

# Email address for Let's Encrypt certificate notifications
# ONLY NEEDED if you configure Caddy for public internet with Let's Encrypt
# Leave commented for local network deployments with self-signed certificates
# ACME_EMAIL=your-email@example.com

# -----------------------------------------------------------------------------
# Infrastructure: Authelia Authentication
# -----------------------------------------------------------------------------
# Protects wireguard, ca, and ddns web UIs behind a login portal
# Login portal: https://auth.{DOMAIN}
#
# Secrets (auto-generated by deploy.sh if left empty)
# You can also generate manually: openssl rand -hex 32
AUTHELIA_JWT_SECRET=
AUTHELIA_SESSION_SECRET=
AUTHELIA_STORAGE_ENCRYPTION_KEY=

# Default admin user credentials
# IMPORTANT: Generate a password hash before deploying!
# Generate with: docker run --rm authelia/authelia:latest authelia crypto hash generate argon2 --password 'YOUR_PASSWORD'
AUTHELIA_DEFAULT_USER=admin
AUTHELIA_DEFAULT_PASSWORD_HASH=

# -----------------------------------------------------------------------------
# Infrastructure: WireGuard VPN Configuration (wg-easy)
# -----------------------------------------------------------------------------
# Web UI: http://localhost:51821 or https://wireguard.{DOMAIN}
#
# Server URL/IP for WireGuard - your public IP or DDNS hostname
# IMPORTANT: Set this to your actual public IP or domain
# Example: vpn.yourdomain.com or 1.2.3.4
WIREGUARD_SERVERURL=auto

# WireGuard server port (UDP) - must be port-forwarded on your router
WIREGUARD_SERVERPORT=51820

# Web UI password hash (bcrypt)
# Generate with: docker run -it ghcr.io/wg-easy/wg-easy wgpw 'YOUR_PASSWORD'
# Leave empty for no password (NOT recommended)
WIREGUARD_PASSWORD_HASH=

# Web UI language (en, de, fr, etc.)
WIREGUARD_LANGUAGE=en

# DNS server for peers
# Use 1.1.1.1 (Cloudflare) or 8.8.8.8 (Google) or your local DNS
WIREGUARD_PEERDNS=1.1.1.1

# Allowed IPs for peers - which traffic goes through VPN
# 0.0.0.0/0 = all traffic (full tunnel)
# 192.168.1.0/24 = only home network traffic (split tunnel)
WIREGUARD_ALLOWEDIPS=0.0.0.0/0

# -----------------------------------------------------------------------------
# Arr-Stack: Application-Specific Settings
# -----------------------------------------------------------------------------
# Deluge torrent client log level
# Options: error, warning, info, debug
DELUGE_LOGLEVEL=error

# Jellyseerr log level
# Options: error, warn, info, debug
# WARNING: debug mode logs sensitive information - use only for troubleshooting
JELLYSEERR_LOG_LEVEL=debug

# Homarr encryption key for securing sensitive data
# IMPORTANT: Generate a unique 64-character hex key before deploying
# Generate with: openssl rand -hex 32
HOMARR_SECRET_KEY=

# -----------------------------------------------------------------------------
# Arr-Stack: VPN Configuration (Gluetun - for torrent traffic)
# -----------------------------------------------------------------------------
# VPN provider to use - supports Mullvad and NordVPN
# Options: mullvad, nordvpn
VPN_SERVICE_PROVIDER=nordvpn

# VPN protocol type
# Options: wireguard (recommended for speed), openvpn (better compatibility)
VPN_TYPE=wireguard

# Mullvad Configuration (when VPN_SERVICE_PROVIDER=mullvad)
# Get WireGuard configuration from: https://mullvad.net/account
# Generate a WireGuard key and download the configuration file
MULLVAD_PRIVATE_KEY=
MULLVAD_ADDRESSES=
# Optional: Specify server cities (comma-separated)
# Example: Amsterdam,Stockholm,Berlin
MULLVAD_SERVER_CITIES=

# NordVPN Configuration (when VPN_SERVICE_PROVIDER=nordvpn)
# For OpenVPN: Use service credentials from https://my.nordaccount.com/
# NOTE: These are NOT your NordVPN account credentials (use service credentials)
NORDVPN_USER=
NORDVPN_PASSWORD=
# For WireGuard: Generate private key at https://my.nordaccount.com/ under NordLynx
# Set VPN_TYPE=wireguard and provide the private key below
WIREGUARD_PRIVATE_KEY=
# Optional: Specify server countries (comma-separated, full names)
# Example: United States,Germany,Switzerland
NORDVPN_SERVER_COUNTRIES=

# -----------------------------------------------------------------------------
# Infrastructure: DDNS Updater Configuration
# -----------------------------------------------------------------------------
# Enable DDNS auto-configuration from .env (set to true to enable)
DDNS_ENABLED=false

# DDNS Provider (cloudflare, namecheap, duckdns, etc.)
# See: https://github.com/qdm12/ddns-updater#providers
DDNS_PROVIDER=cloudflare

# Cloudflare Configuration
DDNS_CLOUDFLARE_TOKEN=
DDNS_CLOUDFLARE_ZONE_ID=
DDNS_DOMAIN=${DOMAIN}
DDNS_HOST=@
DDNS_TTL=300
DDNS_PROXIED=false
DDNS_IP_VERSION=ipv4

# Alternative: Configure via Web UI at http://localhost:8080
# Or manually edit: ${INFRASTRUCTURE_CONFIG_DIR}/ddns-updater/config.json
